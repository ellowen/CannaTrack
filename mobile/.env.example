# ============================================================
# Variables de entorno — copiar a .env.local y completar
# NUNCA commitear .env ni .env.local
# ============================================================

# Entorno: development | preview | production
EXPO_PUBLIC_APP_ENV=development

# Supabase — obtener en dashboard.supabase.com > proyecto > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# RevenueCat — obtener en app.revenuecat.com > proyecto > API Keys
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=

# Sentry — obtener en sentry.io > proyecto > Settings > Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# PostHog — obtener en posthog.com > proyecto > Settings > Project API Key
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# EAS — ID del proyecto en expo.dev (se completa automaticamente con eas init)
EAS_PROJECT_ID=
